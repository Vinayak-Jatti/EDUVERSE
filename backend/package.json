{
  "name": "node-express-mysql-starter",
  "version": "1.0.0",
  "description": "Node.js + Express + MySQL2 — production-grade ES Modules backend",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "node src/database/migrate.js",
    "db:seed": "node src/database/seed.js",
    "db:reset": "node src/database/reset.js",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.config.js",
    "test:integration": "vitest run --config vitest.integration.config.js",
    "test:all": "npm run test:unit && npm run test:integration",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "arctic": "^3.7.0",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "mysql2": "^3.6.5",
    "nodemailer": "^8.0.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "artillery": "^2.0.30",
    "autocannon": "^8.0.0",
    "msms": "^1.0.1",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
